{
  "name": "convo-content-buddy-hotel59-build",
  "image": "ghcr.io/nam20485/convo-content-buddy-hotel59:main-latest",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "DOTNET_ROOT": "/usr/share/dotnet"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-python.python",
        "oven.bun-vscode",
        "avaloniateam.vscode-avalonia"
      ]
    }
  },
  "remoteUser": "vscode"
}
